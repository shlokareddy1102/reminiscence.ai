{
  "name": "reminiscence.ai",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\" \"npm run python:dev\"",
    "start": "npm run server",
    "server": "node server/server.js",
    "server:dev": "nodemon server/server.js",
    "python:dev": "node scripts/run-python-service.js",
    "seed": "node server/seed.js",
    "seed:cohort": "node server/seed_cohort.js",
    "seed:daily-logs": "node server/seed_daily_logs.js",
    "seed:interventions": "node server/seed_interventions.js",
    "patients:list": "node -e \"require('dotenv').config(); const mongoose=require('mongoose'); const Patient=require('./server/models/Patient'); (async()=>{await mongoose.connect(process.env.MONGO_URI||process.env.MONGODB_URI||'mongodb://127.0.0.1:27017/reminiscence'); const rows=await Patient.find({}, {_id:1, name:1}).lean(); console.log(rows); await mongoose.connection.close();})().catch(err=>{console.error(err.message); process.exit(1);});\"",
    "client:dev": "npm --prefix frontend run dev",
    "client:build": "npm --prefix frontend run build",
    "client:preview": "npm --prefix frontend run preview",
    "start:full": "concurrently \"npm run server\" \"npm run client:preview\"",
    "smoke": "node scripts/smoke-test.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "multer": "^2.1.0",
    "pdfkit": "^0.17.2",
    "react-router-dom": "^7.13.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.14"
  }
}
